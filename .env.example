# ──────────────────────────────────────────────────────────────
# Cosmos Pay — payments microservice
# This service is NOT meant to be exposed directly to the internet.
# All traffic must arrive through the APISIX gateway (always enforced — no opt-out).
# ──────────────────────────────────────────────────────────────

# App
NODE_ENV=development
PORT=3000

# PostgreSQL connection used by Prisma (payments DB — independent from the dev platform DB)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cosmos_payments?schema=public

# APISIX gateway validation (always enforced). REQUIRED — must equal the dev platform's
# COSMOS_GATEWAY_SECRET (APISIX injects it as X-Gateway-Secret). `openssl rand -hex 32`.
APISIX_GATEWAY_SECRET=replace-with-a-long-random-secret

# Stellar (payment intents). Fallback network when the gateway didn't forward a key env.
STELLAR_NETWORK=testnet
STELLAR_BASE_FEE=100
STELLAR_TX_TIMEOUT=300

# Observer (on-chain reconciler) + payment intent lifetime
OBSERVER_ENABLED=true
PAYMENT_INTENT_TTL_SECONDS=3600


