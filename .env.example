# ──────────────────────────────────────────────────────────────
# Cosmos Pay — payments microservice
# This service is NOT meant to be exposed directly to the internet.
# All traffic must arrive through the APISIX gateway (always enforced — no opt-out).
# ──────────────────────────────────────────────────────────────

# App
NODE_ENV=development
PORT=3000

# PostgreSQL connection used by Prisma (payments DB — independent from the dev platform DB)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cosmos_payments?schema=public

# APISIX gateway validation (always enforced). REQUIRED — must equal the dev platform's
# COSMOS_GATEWAY_SECRET (APISIX injects it as X-Gateway-Secret). `openssl rand -hex 32`.
APISIX_GATEWAY_SECRET=replace-with-a-long-random-secret

# Stellar (payment intents). Fallback network when the gateway didn't forward a key env.
STELLAR_NETWORK=testnet
STELLAR_BASE_FEE=100
STELLAR_TX_TIMEOUT=300

# Stellar native swaps (path-payment asset exchange). Non-custodial: the service
# only quotes, builds the unsigned tx and submits the signed one. The fee is taken
# in the source asset and paid to STELLAR_SWAP_FEE_WALLET. Leave the wallet blank
# to disable the fee entirely (swaps still work, just with no cut taken).
STELLAR_SWAP_FEE_WALLET=GARMB7W3FCR3GKIM3FLWVJASC2PUZ4VHUJZTNJVWWKNTCJNKO6TBCT76
STELLAR_SWAP_FEE_BPS=50
STELLAR_SWAP_SLIPPAGE_BPS=50
STELLAR_SWAP_MAX_SLIPPAGE_BPS=500

# Observer (on-chain reconciler) + payment intent lifetime
OBSERVER_ENABLED=true
PAYMENT_INTENT_TTL_SECONDS=3600

# ──────────────────────────────────────────────────────────────
# BlindPay — fiat <-> stablecoin rails (onramp / offramp / KYC)
# One platform instance shared by all consumers. Leave blank to disable the
# feature (BlindPay routes then return 503). Get these from the BlindPay
# dashboard: Instance → API Keys. instance id looks like `in_...`.
# ──────────────────────────────────────────────────────────────
BLINDPAY_API_KEY=
BLINDPAY_INSTANCE_ID=
BLINDPAY_BASE_URL=https://api.blindpay.com/v1
# Svix signing secret (whsec_...) of the webhook endpoint you point at
# <gateway>/v1/blindpay/webhooks. Required to accept BlindPay webhooks.
BLINDPAY_WEBHOOK_SECRET=
BLINDPAY_TIMEOUT_MS=15000


