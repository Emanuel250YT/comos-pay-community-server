# ──────────────────────────────────────────────────────────────
# Cosmos Pay — payments microservice
# This service is NOT meant to be exposed directly to the internet.
# All traffic must arrive through the APISIX gateway.
# ──────────────────────────────────────────────────────────────

# App
NODE_ENV=development
PORT=3000

# PostgreSQL connection used by Prisma (payments database — independent from the dev platform DB)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cosmos_payments?schema=public

# ──────────────────────────────────────────────────────────────
# APISIX gateway validation
# ──────────────────────────────────────────────────────────────
# Shared secret that APISIX injects on every proxied request (via the
# `proxy-rewrite` plugin: headers.set["X-Gateway-Secret"]). Because APISIX
# also *removes* any client-supplied X-Gateway-Secret, a request carrying the
# correct value can only have come from the gateway. Generate a long random
# value, e.g. `openssl rand -hex 32`.
APISIX_GATEWAY_SECRET=replace-with-a-long-random-secret

# Header names APISIX uses to forward gateway / consumer context downstream.
# Defaults match APISIX's key-auth behaviour; override only if your route remaps them.
APISIX_GATEWAY_SECRET_HEADER=x-gateway-secret
APISIX_CONSUMER_HEADER=x-consumer-username
APISIX_CREDENTIAL_HEADER=x-credential-identifier
# Header carrying the API key environment (derived by APISIX from the key prefix:
# `dv_` → dev, `prod_` → prod). It decides the Stellar network of each intent.
APISIX_ENVIRONMENT_HEADER=x-consumer-env
# Headers carrying the API key's authorization context, forwarded per-credential by
# APISIX (a serverless-pre-function baked into each key). The PermissionsGuard enforces
# `resource:action` scopes (e.g. payments:write); `admin` role bypasses all scopes.
APISIX_ROLE_HEADER=x-consumer-role
APISIX_PERMISSIONS_HEADER=x-consumer-permissions

# When true, the gateway guard is enforced. Set to false ONLY for local
# development where you call the service without going through APISIX.
ENFORCE_GATEWAY=true

# ──────────────────────────────────────────────────────────────
# Stellar (payment intents)
# ──────────────────────────────────────────────────────────────
# The network of each intent follows the caller's API key type (dev → testnet,
# prod → public). STELLAR_NETWORK is only the FALLBACK used when the gateway
# didn't forward an environment (e.g. local dev without APISIX).
STELLAR_NETWORK=testnet
# Optional Horizon overrides per network (defaults to the canonical endpoints).
# STELLAR_HORIZON_URL_PUBLIC=https://horizon.stellar.org
# STELLAR_HORIZON_URL_TESTNET=https://horizon-testnet.stellar.org
# Base fee in stroops per operation.
STELLAR_BASE_FEE=100
# Transaction validity window in seconds.
STELLAR_TX_TIMEOUT=300

# ──────────────────────────────────────────────────────────────
# Observer (permanent on-chain reconciler)
# ──────────────────────────────────────────────────────────────
# Polls Horizon for matching payments to PENDING intents, finalizes them
# (status + txHash) and fires webhook events automatically.
OBSERVER_ENABLED=true
# How often to reconcile (ms).
OBSERVER_INTERVAL_MS=15000
# Max pending intents reconciled per cycle.
OBSERVER_BATCH_SIZE=50

# Lifetime of a payment intent (seconds). Unpaid intents past this are auto-EXPIRED
# by the observer. Default 3600 (1 hour).
PAYMENT_INTENT_TTL_SECONDS=3600

# ──────────────────────────────────────────────────────────────
# Webhooks (notifications to integrators)
# ──────────────────────────────────────────────────────────────
# Per-attempt HTTP timeout when POSTing to an integrator's endpoint.
WEBHOOK_TIMEOUT_MS=5000
# Total attempts per delivery before it is marked FAILED.
WEBHOOK_MAX_ATTEMPTS=3
# Base backoff between attempts (grows linearly: 1x, 2x, 3x ...).
WEBHOOK_BACKOFF_MS=2000
# Header carrying the HMAC signature (Stripe-style: `t=<ts>,v1=<hex>`).
WEBHOOK_SIGNATURE_HEADER=x-cosmos-signature
