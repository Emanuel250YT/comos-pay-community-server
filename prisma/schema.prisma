// Cosmos Pay — payments microservice
// Independent datastore from the developer platform. This service only ever
// receives traffic that has already been authenticated by APISIX (key-auth),
// so it trusts the consumer identity forwarded by the gateway and keys its
// own records to that consumer.

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// A consumer mirrors the APISIX consumer that authenticated the request.
// We do not store credentials here — only the gateway-provided identity, so
// payments can be attributed and listed per consumer.
model Consumer {
  id             String   @id @default(cuid())
  // The APISIX consumer username, e.g. `cosmos_<userId>` (X-Consumer-Username).
  apisixUsername String   @unique
  // The credential id that authenticated, e.g. `cosmos_<uuid>` (X-Credential-Identifier).
  credentialId   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  paymentIntents   PaymentIntent[]
  webhookEndpoints WebhookEndpoint[]
  products         Product[]
  customers        Customer[]
  swaps            Swap[]

  // BlindPay (onramp/offramp/KYC) resources mirrored from the provider.
  blindpayReceivers BlindpayReceiver[]
  payins            Payin[]
  payouts           Payout[]

  @@map("consumer")
}

// A merchant-managed customer record. Independent of the payers derived from
// payment intents — these are explicitly created/edited by the merchant.
model Customer {
  id          String   @id @default(cuid())
  consumerId  String
  consumer    Consumer @relation(fields: [consumerId], references: [id], onDelete: Cascade)

  name        String
  // A friendly display alias the merchant can assign (e.g. "Acme — billing").
  alias       String?
  email       String?
  // Optional Stellar account to associate the customer with on-chain activity.
  account     String?
  note        String? // free-form merchant note
  reference   String? // merchant reference / external id

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([consumerId])
  @@map("customer")
}

// Append-only access log of API requests reaching the service (written by the
// LoggingInterceptor). Powers the dashboard "API logs" view. Scoped by the
// forwarded consumer username when present.
model RequestLog {
  id          String   @id @default(cuid())
  // APISIX consumer username (X-Consumer-Username), null for anonymous/public.
  consumer    String?
  method      String
  path        String
  statusCode  Int
  durationMs  Int
  ip          String?
  userAgent   String?

  createdAt   DateTime @default(now())

  @@index([consumer])
  @@index([createdAt])
  @@map("request_log")
}

// A reusable item/price a merchant can charge for. Independent of payment
// intents — intents may reference one via `reference`, but products are managed
// on their own. Scoped to the APISIX consumer that created them.
model Product {
  id          String   @id @default(cuid())
  consumerId  String
  consumer    Consumer @relation(fields: [consumerId], references: [id], onDelete: Cascade)

  name        String
  description String?
  // Price as a decimal string (e.g. "49.00"). Null = customer-set / donation.
  amount      String?
  asset       String   @default("native") // asset code, or "native" for XLM
  // 'recurring' | 'one_time' | 'link' — informational classification.
  kind        String   @default("one_time")
  active      Boolean  @default(true)
  reference   String? // optional merchant SKU / reference

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([consumerId])
  @@map("product")
}

// Events the platform emits to integrators' webhook endpoints.
enum WebhookEventType {
  PAYMENT_INTENT_CREATED
  PAYMENT_INTENT_UPDATED
  PAYMENT_INTENT_SUCCEEDED
  PAYMENT_INTENT_FAILED
  PAYMENT_INTENT_CANCELLED
  PAYMENT_INTENT_DELETED

  // BlindPay-sourced events re-emitted to integrators after we sync state.
  RECEIVER_UPDATED
  PAYIN_CREATED
  PAYIN_UPDATED
  PAYIN_COMPLETED
  PAYOUT_CREATED
  PAYOUT_UPDATED
  PAYOUT_COMPLETED

  // Stellar native swaps (path-payment based asset exchange).
  SWAP_CREATED
  SWAP_SUBMITTED
  SWAP_SUCCEEDED
  SWAP_FAILED
}

enum WebhookDeliveryStatus {
  PENDING
  SUCCEEDED
  FAILED
}

// An integrator-registered URL that receives signed event notifications.
// Scoped to the APISIX consumer that created it.
model WebhookEndpoint {
  id          String             @id @default(cuid())
  consumerId  String
  consumer    Consumer           @relation(fields: [consumerId], references: [id], onDelete: Cascade)

  url         String
  // HMAC-SHA256 signing secret (prefixed `whsec_`). Integrators verify the
  // `X-Cosmos-Signature` header with this.
  secret      String
  description String?
  enabled     Boolean            @default(true)
  // Subscribed event types; an empty list means "all events".
  eventTypes  WebhookEventType[]

  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  deliveries  WebhookDelivery[]

  @@index([consumerId])
  @@map("webhook_endpoint")
}

// Append-only record of every delivery attempt — the audit trail for what the
// platform notified, when, and whether the integrator acknowledged it.
model WebhookDelivery {
  id             String                @id @default(cuid())
  endpointId     String
  endpoint       WebhookEndpoint       @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  eventType      WebhookEventType
  // Stable event id sent to the receiver for idempotency.
  eventId        String
  payload        Json
  status         WebhookDeliveryStatus @default(PENDING)
  attempts       Int                   @default(0)
  responseStatus Int?
  error          String?
  lastAttemptAt  DateTime?

  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@index([endpointId])
  @@index([status])
  @@index([eventId])
  @@map("webhook_delivery")
}

// Lifecycle of a Stellar payment intent. Kept for traceability — the unsigned
// transaction (xdr/uri) is persisted at creation and the status is advanced as
// the customer signs/submits it on the network.
enum PaymentIntentStatus {
  PENDING // created, unsigned tx handed to the customer
  SUBMITTED // a signed tx hash was reported back to us
  SUCCEEDED // confirmed on the Stellar network
  FAILED // rejected / errored on the network
  CANCELLED // abandoned by the merchant/customer
  EXPIRED // tx time bounds elapsed before submission
}

// How the intent was assembled:
//  - TX:  source known → a full unsigned transaction (xdr) + SEP-7 `tx` URI.
//  - PAY: no source → only a SEP-7 `pay` URI (destination[, amount, asset]); no xdr.
enum PaymentIntentKind {
  TX
  PAY
}

model PaymentIntent {
  id          String              @id @default(cuid())
  consumerId  String
  consumer    Consumer            @relation(fields: [consumerId], references: [id], onDelete: Cascade)

  kind        PaymentIntentKind   @default(TX)

  // Stellar payment details.
  source      String? // payer account (G...) — null for PAY intents
  destination String // payee account (G...)
  amount      String? // decimal string, e.g. "25.5" — optional for PAY intents
  asset       String              @default("native") // asset code, or "native" for XLM
  assetIssuer String? // issuer account for non-native assets
  // Mandatory MEMO_ID (uint64 as string). Auto-generated when not supplied.
  // Identifies the payment on-chain and gives the intent idempotency per consumer.
  memo        String
  network     String // 'public' | 'testnet'

  // Optional SEP-7 extras (informational; echoed back, not validated on-chain).
  msg         String? // message shown to the user in their wallet
  callback    String? // SEP-7 callback (e.g. `url:https://...`)

  status      PaymentIntentStatus @default(PENDING)

  // Artifacts. `xdr` is null for PAY intents; QR is derived from `uri` on read.
  xdr         String?
  uri         String
  // Set once a signed transaction is submitted/confirmed.
  txHash      String?             @unique
  reference   String? // optional merchant reference

  // Lifetime: an unpaid intent past this instant is auto-finalized to EXPIRED by
  // the observer. Set at creation from the configured TTL.
  expiresAt   DateTime?

  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@unique([consumerId, memo]) // idempotency: one intent per (consumer, memo)
  @@index([consumerId])
  @@index([status])
  @@map("payment_intent")
}

// ---------------------------------------------------------------------------
// BlindPay (fiat <-> stablecoin rails): onramp / offramp / KYC.
//
// We run a single platform BlindPay instance (one API key + instance id in env)
// and mirror the provider's resources here, each scoped to the APISIX consumer
// that created it. Status/type/rail/network/token are stored as free-form
// strings (like Product.kind) so new provider values never require a migration.
// `raw` keeps the last full provider payload for audit/debugging.
// ---------------------------------------------------------------------------

// A KYC/KYB entity at BlindPay (their `receiver`/`customer`, id `re_...`).
// Every end user transacting through the rails must exist as a receiver.
model BlindpayReceiver {
  id          String   @id @default(cuid())
  consumerId  String
  consumer    Consumer @relation(fields: [consumerId], references: [id], onDelete: Cascade)

  // BlindPay receiver id (`re_...`).
  blindpayId  String
  // 'individual' | 'business'.
  type        String
  // 'light' | 'standard' | 'enhanced'.
  kycType     String?
  // BlindPay KYC status. Receivers start as 'inactive' (created locally, not yet at
  // BlindPay) until the terms-of-service are accepted and the receiver is enabled,
  // at which point this becomes BlindPay's real status — see ReceiversService.
  kycStatus   String?
  email       String?
  name        String?
  country     String?
  externalId  String?
  reference   String? // optional merchant reference

  // Last time a terms-of-service link was emailed for this receiver — rate limits the
  // "email me the ToS" action to at most once per day.
  tosSentAt   DateTime?

  // Owner/admin kill-switch for this fiat account: when true the receiver cannot be
  // used for onramp/offramp (quotes, payins, payouts, new wallets/bank accounts are
  // refused) regardless of its BlindPay KYC status. Toggled by a platform owner/admin.
  disabled    Boolean   @default(false)

  raw         Json?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  blockchainWallets BlindpayBlockchainWallet[]
  bankAccounts      BlindpayBankAccount[]
  virtualAccounts   BlindpayVirtualAccount[]
  payins            Payin[]
  payouts           Payout[]

  @@unique([consumerId, blindpayId])
  @@index([consumerId])
  @@map("blindpay_receiver")
}

// A receiver's blockchain wallet at BlindPay (id `bw_...`). Destination for
// onramp (minted stablecoin) and source for offramp.
model BlindpayBlockchainWallet {
  id          String           @id @default(cuid())
  consumerId  String
  receiverId  String
  receiver    BlindpayReceiver @relation(fields: [receiverId], references: [id], onDelete: Cascade)

  blindpayId  String // `bw_...`
  name        String?
  network     String
  address     String?
  isAccountAbstraction Boolean @default(false)

  raw         Json?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([consumerId, blindpayId])
  @@index([consumerId])
  @@index([receiverId])
  @@map("blindpay_blockchain_wallet")
}

// A receiver's fiat bank account at BlindPay (id `ba_...`). Destination for
// offramp payouts. `rail` is the BlindPay rail/type (ach, wire, pix, spei, ...).
model BlindpayBankAccount {
  id          String           @id @default(cuid())
  consumerId  String
  receiverId  String
  receiver    BlindpayReceiver @relation(fields: [receiverId], references: [id], onDelete: Cascade)

  blindpayId  String // `ba_...`
  rail        String?
  name        String?
  country     String?

  raw         Json?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([consumerId, blindpayId])
  @@index([consumerId])
  @@index([receiverId])
  @@map("blindpay_bank_account")
}

// A dedicated fiat account (id `va_...`) that auto-converts incoming fiat into
// stablecoin to the linked blockchain wallet — onramp infrastructure.
model BlindpayVirtualAccount {
  id                 String           @id @default(cuid())
  consumerId         String
  receiverId         String
  receiver           BlindpayReceiver @relation(fields: [receiverId], references: [id], onDelete: Cascade)

  blindpayId         String // `va_...`
  blockchainWalletId String?
  token              String?
  status             String?

  raw                Json?

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([consumerId, blindpayId])
  @@index([consumerId])
  @@index([receiverId])
  @@map("blindpay_virtual_account")
}

// Onramp (fiat -> stablecoin). Created from a payin quote; carries the payment
// instructions the payer follows (memo/CLABE/PIX/CBU/PSE/bank details).
model Payin {
  id             String           @id @default(cuid())
  consumerId     String
  consumer       Consumer         @relation(fields: [consumerId], references: [id], onDelete: Cascade)
  receiverId     String?
  receiver       BlindpayReceiver? @relation(fields: [receiverId], references: [id], onDelete: SetNull)

  blindpayId     String // `pi_...`
  quoteId        String?
  status         String?
  token          String?
  network        String?
  paymentMethod  String? // rail used to pay in
  currency       String?
  senderAmount   String?
  receiverAmount String?
  // Provider-supplied instructions the payer follows to fund the payin.
  instructions   Json?

  raw            Json?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([consumerId, blindpayId])
  @@index([consumerId])
  @@index([receiverId])
  @@index([status])
  @@map("payin")
}

// Offramp (stablecoin -> fiat). Created from a payout quote; the customer signs
// the on-chain transfer (we never hold keys), funds settle to a bank account.
model Payout {
  id                  String           @id @default(cuid())
  consumerId          String
  consumer            Consumer         @relation(fields: [consumerId], references: [id], onDelete: Cascade)
  receiverId          String?
  receiver            BlindpayReceiver? @relation(fields: [receiverId], references: [id], onDelete: SetNull)

  blindpayId          String // `pa_...`
  quoteId             String?
  status              String?
  token               String?
  network             String?
  rail                String?
  bankAccountId       String?
  senderAmount        String?
  receiverAmount      String?
  senderWalletAddress String?

  raw                 Json?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([consumerId, blindpayId])
  @@index([consumerId])
  @@index([receiverId])
  @@index([status])
  @@map("payout")
}

// ---------------------------------------------------------------------------
// Stellar native swaps (asset exchange via path payments).
//
// Stellar has no "swap" primitive — asset exchange is a `PathPaymentStrictSend`
// operation that routes through the DEX order books and AMM liquidity pools to
// the best available path. This service is **non-custodial**: it only quotes,
// assembles the unsigned transaction (a platform fee payment + the path payment)
// and submits the signed transaction the customer hands back. Funds never pass
// through Cosmos Pay. Scoped to the APISIX consumer like every other resource.
// ---------------------------------------------------------------------------
enum SwapStatus {
  PENDING // built, unsigned XDR handed to the customer
  SUBMITTED // a signed tx was submitted to the network
  SUCCEEDED // confirmed on the Stellar network
  FAILED // rejected / errored on the network
  EXPIRED // tx time bounds elapsed before submission
}

model Swap {
  id          String     @id @default(cuid())
  consumerId  String
  consumer    Consumer   @relation(fields: [consumerId], references: [id], onDelete: Cascade)

  network     String // 'public' | 'testnet'
  // Account paying (and signing) the swap.
  source      String
  // Account credited the destination asset (defaults to `source` — a self-swap).
  destination String

  // Source side (asset sold). `sendAmount` is the gross input; the platform fee
  // is deducted from it and `swapAmount` (= sendAmount - feeAmount) is routed.
  sendAsset       String  @default("native") // asset code, or "native" for XLM
  sendAssetIssuer String?
  sendAmount      String
  feeAmount       String
  feeBps          Int
  swapAmount      String

  // Destination side (asset bought). `destEstimated` is the quote at build time;
  // `destMin` is the slippage-protected minimum enforced on-chain (destMin).
  destAsset       String  @default("native")
  destAssetIssuer String?
  destEstimated   String
  destMin         String
  slippageBps     Int
  // Intermediate hops chosen by the path search: [{ code, issuer }] (or empty).
  path            Json

  // Optional MEMO_ID echoed on-chain for the merchant's own reconciliation.
  memo        String?

  status      SwapStatus @default(PENDING)
  // Unsigned transaction envelope + its SEP-7 `tx` deep link. QR derived on read.
  xdr         String
  uri         String
  // Deterministic transaction hash (computed at build, verified on submit).
  txHash      String

  expiresAt   DateTime?

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([consumerId])
  @@index([status])
  @@index([txHash])
  @@map("swap")
}
